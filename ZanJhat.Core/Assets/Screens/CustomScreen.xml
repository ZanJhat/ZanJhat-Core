<Screen xmlns="runtime-namespace:Game">

    <PanoramaWidget />

    <StackPanelWidget Direction="Horizontal">

        <CanvasWidget Style="{Widgets/TopBarContents}">
            <LabelWidget Name="TopBar.Label" />
        </CanvasWidget>

        <CanvasWidget Margin="10, 20">
            <BevelledRectangleWidget Style="{Styles/Area}" />
            
            <ScrollPanelWidget Name="ScrollPanel" Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3, 3">
                <StackPanelWidget Name="ContentsStackPanel" Direction="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="false" />
            </ScrollPanelWidget>
            
        </CanvasWidget>

    </StackPanelWidget>

</Screen>