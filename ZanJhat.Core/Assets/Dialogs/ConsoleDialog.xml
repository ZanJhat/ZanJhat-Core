<CanvasWidget xmlns="runtime-namespace:Game">

    <CanvasWidget Size="600, 420" ClampToBounds="true" HorizontalAlignment="Center" VerticalAlignment="Center">
        <BevelledRectangleWidget Style="{Styles/DialogArea}" />

        <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" Margin="10, 0" IsVisible="true">

            <StackPanelWidget Direction="Vertical">

                <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <LabelWidget Text="Console" HorizontalAlignment="Center" Margin="0, 15" />
                </StackPanelWidget>

                <CanvasWidget Size="Infinity, Infinity">
                    <StackPanelWidget Direction="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <CanvasWidget Size="560, Infinity" VerticalAlignment="Center">
                        	<BevelledRectangleWidget Style="{Styles/TextBoxArea}" />
                            <ScrollPanelWidget Name="LogScrollPanel" Direction="Vertical" Margin="5, 5" ClampToBounds="true">
                            	<StackPanelWidget Name="LogStackPanel" Direction="Vertical" HorizontalAlignment="Near" />
                            </ScrollPanelWidget>
                        </CanvasWidget>
                       
                    </StackPanelWidget>
                </CanvasWidget>

            </StackPanelWidget>

            <StackPanelWidget Direction="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10, 15">
            	
                <BevelledButtonWidget Size="60, 60" FontScale="1.25" HorizontalAlignment="Center" Name="QCButton" Text="/" />
                
                <CanvasWidget Size="Infinity, 50" HorizontalAlignment="Center" VerticalAlignment="Center">
                	<BevelledRectangleWidget Style="{Styles/TextBoxArea}" />
                	<TextBoxWidget Size="Infinity, Infinity" Name="InputTextBox" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5, 0" />
                </CanvasWidget>
                
                <BevelledButtonWidget Size="60, 60" HorizontalAlignment="Center" Name="SendButton">
                	<RectangleWidget Size="24, 24" OutlineColor="0, 0, 0, 0" FillColor="255, 255, 255" Subtexture="{Textures/Gui/To}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </BevelledButtonWidget>
                
                <BevelledButtonWidget Size="60, 60" HorizontalAlignment="Center" Name="CancelButton">
                	<RectangleWidget Size="40, 40" OutlineColor="0, 0, 0, 0" FillColor="255, 255, 255" Subtexture="{Textures/Gui/Unavailable}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </BevelledButtonWidget>
                
            </StackPanelWidget>

        </StackPanelWidget>

    </CanvasWidget>
</CanvasWidget>